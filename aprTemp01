  function setActiveCard() {
    $('.owl-carousel .owl-item .slider-wrapper').removeClass('active');
    var $visibleItems = $('.owl-carousel .owl-item.active');
    $visibleItems.eq(0).find('.slider-wrapper').addClass('active');
  }

  $owl.on('initialized.owl.carousel translated.owl.carousel', function () {
    setActiveCard();
  });

  setActiveCard();

  // On hover: remove active from 2nd card
  // On mouse leave: restore active to 2nd card
  $(document).on('mouseenter', '.owl-item .slider-wrapper', function () {
    $('.owl-carousel .owl-item .slider-wrapper').removeClass('active');
  });

  $(document).on('mouseleave', '.owl-item .slider-wrapper', function () {
    setActiveCard();
  });

});
</script>


